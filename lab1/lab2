# БЛОК 15: ИТОГОВЫЕ ГРАФИКИ ДЛЯ РУКОВОДСТВА

fig, axes = plt.subplots(2, 2, figsize=(14, 12))

# График: распределение качества водителей (гистограмма + кривая плотности)
sns.histplot(driver_metrics['driver_quality_score'], bins=30, kde=True, ax=axes[0,0])
